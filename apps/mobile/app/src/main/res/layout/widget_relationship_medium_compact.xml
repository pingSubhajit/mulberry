<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@android:id/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_relationship_bg"
    android:clipToOutline="true">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.2"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/widget_relationship_doodles" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="fitXY"
            android:src="@drawable/widget_relationship_gradient_overlay" />

        <ImageView
            android:id="@+id/widget_relationship_squee"
            android:layout_width="270dp"
            android:layout_height="match_parent"
            android:layout_gravity="bottom|start"
            android:adjustViewBounds="true"
            android:contentDescription="@null"
            android:scaleType="fitStart"
            android:src="@drawable/widget_squee_default" />

        <ImageView
            android:id="@+id/widget_relationship_content_stack"
            android:layout_width="300dp"
            android:layout_height="174dp"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="26dp"
            android:contentDescription="@null"
            android:scaleType="fitCenter" />
    </FrameLayout>
