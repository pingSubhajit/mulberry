<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@android:id/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_relationship_bg"
    android:clipToOutline="true">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.2"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/widget_relationship_doodles" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="fitXY"
            android:src="@drawable/widget_relationship_gradient_overlay" />

        <ImageView
            android:id="@+id/widget_relationship_squee"
            android:layout_width="320dp"
            android:layout_height="match_parent"
            android:layout_gravity="bottom|start"
            android:adjustViewBounds="true"
            android:contentDescription="@null"
            android:scaleType="fitStart"
            android:src="@drawable/widget_squee_default" />

        <ImageView
            android:id="@+id/widget_relationship_badge"
            android:layout_width="79dp"
            android:layout_height="79dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="@null"
            android:src="@drawable/widget_relationship_badge" />

        <LinearLayout
            android:id="@+id/widget_relationship_text_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical|end"
            android:orientation="vertical"
            android:paddingEnd="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/widget_relationship_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:includeFontPadding="false"
                android:text="2 years"
                android:textColor="#D81012"
                android:textSize="64sp" />

            <TextView
                android:id="@+id/widget_relationship_secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/poppins_bold"
                android:includeFontPadding="false"
                android:text="and 256 days"
                android:textColor="@android:color/black"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/widget_relationship_caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/poppins_medium"
                android:includeFontPadding="false"
                android:text="Wow, 14 days to 1000!!"
                android:textColor="@android:color/black"
                android:textSize="14sp" />
        </LinearLayout>
</FrameLayout>
