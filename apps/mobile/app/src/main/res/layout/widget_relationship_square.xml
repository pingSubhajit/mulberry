<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@android:id/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_relationship_bg"
    android:clipToOutline="true">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.2"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/widget_relationship_doodles" />

    <ImageView
        android:id="@+id/widget_relationship_squee"
        android:layout_width="188dp"
        android:layout_height="158dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="-30dp"
        android:layout_marginTop="-22dp"
        android:adjustViewBounds="true"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/widget_squee_default_square" />

    <ImageView
        android:id="@+id/widget_relationship_compact_cluster"
        android:layout_width="168dp"
        android:layout_height="132dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="8dp"
        android:contentDescription="@null"
        android:scaleType="fitEnd" />
</FrameLayout>
